{
  "name": "roomind-app",
  "main": "expo-router/entry",
  "version": "1.7.0",
  "private": true,
  "scripts": {
    "dev": "npx expo start --web",
    "build:web": "expo export --platform web --output-dir dist",
    "build": "expo export --platform web --output-dir dist",
    "preview": "npx serve dist",
    "lint": "expo lint",
    "postinstall": "cat > node_modules/caller-callsite/index.js << 'EOF'\n'use strict';\n\n// Patch per ambiente web: evita crash quando callsites() non è disponibile\nmodule.exports = function (depth) {\n  try {\n    const callsites = require('callsites');\n    const cs = callsites();\n    const callsite = cs[depth + 1];\n    // Assicurati che venga sempre restituito un oggetto valido\n    return callsite || {\n      getFileName: () => null\n    };\n  } catch (e) {\n    return {\n      getFileName: () => null\n    };\n  }\n};\nEOF"
  },
  "dependencies": {
    "@expo/vector-icons": "^14.0.0",
    "@react-native-async-storage/async-storage": "^2.0.0",
    "expo": "^52.0.0",
    "expo-constants": "~16.0.0",
    "expo-font": "~12.0.0",
    "expo-linear-gradient": "~13.0.0",
    "expo-linking": "~6.3.0",
    "expo-localization": "~15.0.0",
    "expo-router": "^3.5.0",
    "expo-splash-screen": "~0.27.0",
    "expo-status-bar": "~1.12.0",
    "expo-system-ui": "~3.0.0",
    "expo-web-browser": "~13.0.0",
    "lucide-react-native": "^0.475.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-native": "0.75.3",
    "react-native-gesture-handler": "~2.19.0",
    "react-native-reanimated": "~3.15.0",
    "react-native-safe-area-context": "4.11.0",
    "react-native-screens": "3.34.0",
    "react-native-svg": "15.6.0",
    "react-native-web": "~0.19.12"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@types/react": "~18.2.45",
    "@types/node": "^24.3.0"
  }
}